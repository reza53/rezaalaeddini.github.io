<!doctype html>
<html>
  <head>
    {% include head.liquid %}

    <!-- Distill JS -->
    <script src="{{ '/assets/js/distillpub/template.v2.js' | relative_url }}"></script>
    <script src="{{ '/assets/js/distillpub/transforms.v2.js' | relative_url }}"></script>

    {% if page._styles %}
      <!-- Page-specific styles -->
      <style type="text/css">
        {{ page._styles }}
      </style>
    {% endif %}
  </head>

  <d-front-matter>
    <script async type="text/json">
      {
        "title": "{{ page.title }}",
        "description": "{{ page.description }}",
        "published": "{{ page.date | date: '%B %d, %Y' }}",
        "authors": [
          {% for author in page.authors %}
          {
            "author": "{{ author.name }}",
            "authorURL": "{{ author.url }}",
            "affiliations": [
              {
                "name": "{{ author.affiliations.name }}",
                "url": "{{ author.affiliations.url }}"
              }
            ]
          }{% if forloop.last == false %},{% endif %}
          {% endfor %}
        ],
        "katex": {
          "delimiters": [
            { "left": "$", "right": "$", "display": false },
            { "left": "$$", "right": "$$", "display": true }
          ]
        },
        "citation": {
          "bibliography": "{{ page.bibliography }}",
          "citationStyle": "apa"
        }
      }
    </script>
  </d-front-matter>

  <body class="{% if site.navbar_fixed %}fixed-top-nav{% endif %} {% unless site.footer_fixed %}sticky-bottom-footer{% endunless %}">

    <!-- Header -->
    {% include header.liquid %}

    <!-- Main Post Content -->
    <div class="post distill">

      <d-title>
        <h1>{{ page.title }}</h1>
        <p>{{ page.description }}</p>
      </d-title>

      {% if page.authors %}
        <d-byline></d-byline>
      {% endif %}

      <d-article>
        {% if page.toc %}
          <d-contents>
            <nav class="l-text figcaption">
              <h3>Contents</h3>
              {% for section in page.toc %}
                <div>
                  <a href="#{{ section.name | slugify }}">{{ section.name }}</a>
                </div>
                {% if section.subsections %}
                  <ul>
                    {% for subsection in section.subsections %}
                      <li><a href="#{{ subsection.name | slugify }}">{{ subsection.name }}</a></li>
                    {% endfor %}
                  </ul>
                {% endif %}
              {% endfor %}
            </nav>
          </d-contents>
        {% endif %}
        {{ content }}
      </d-article>

      <d-appendix>
        <d-footnote-list></d-footnote-list>
        <d-citation-list></d-citation-list>
      </d-appendix>

      {% if page.bibliography %}
        <d-bibliography src="{{ page.bibliography | relative_url }}"></d-bibliography>
      {% endif %}

      {% if site.disqus_shortname and page.disqus_comments %}
        {% include disqus.liquid %}
      {% endif %}

      {% if site.giscus.repo and page.giscus_comments %}
        {% include giscus.liquid %}
      {% endif %}
    </div>

    <!-- Footer -->
    {% include footer.liquid %}

    <!-- Default JavaScripts -->
    {% include distill_scripts.liquid %}

    <!-- Pyodide support for editable Python blocks -->
    <script src="https://cdn.jsdelivr.net/pyodide/v0.25.1/full/pyodide.js"></script>
    <script>
      async function enablePythonExecution() {
        const pyodide = await loadPyodide();

        await pyodide.runPythonAsync(`
import sys
from js import console

class StdoutCatcher:
    def __init__(self):
        self.data = ""
    def write(self, s):
        self.data += s
        console.log(s)
    def flush(self): pass

sys.stdout = StdoutCatcher()
sys.stderr = sys.stdout
        `);

        document.querySelectorAll('d-code[language="python"][editable]').forEach((block) => {
          const code = block.textContent.trim();
          const button = document.createElement("button");
          button.textContent = "▶ Run";
          button.className = "run-button";
          button.style.margin = "0.5em 0";
          button.style.padding = "0.2em 0.6em";

          const output = document.createElement("pre");
          output.className = "code-output";
          output.style.background = "#f7f7f7";
          output.style.border = "1px solid #ccc";
          output.style.padding = "0.5em";
          output.style.whiteSpace = "pre-wrap";
          output.style.fontSize = "0.9em";

          button.onclick = async () => {
            try {
              await pyodide.runPythonAsync(`sys.stdout.data = ""`);
              await pyodide.runPythonAsync(code);
              const result = await pyodide.runPythonAsync("sys.stdout.data");
              output.textContent = result.trim() || "(no output)";
            } catch (err) {
              output.textContent = "⚠️ Error: " + err;
            }
          };

          block.after(button, output);
        });
      }

      enablePythonExecution();
    </script>

  </body>
</html>
